generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  TRAINER
  DTC
  STC
  ADMIN
}

enum AssignmentStatus {
  ASSIGNED
  PENDING
  COMPLETED
}

enum AttemptStatus {
  SUBMITTED
  PASSED
  FAILED
}

model User {
  id            String   @id @default(uuid())
  employeeId    String   @unique
  name          String
  email         String   @unique
  passwordHash  String
  role          Role     @default(USER)
  department    String
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  assignments       TrainingAssignment[] @relation("assignee")
  assignmentsMade   TrainingAssignment[] @relation("assigner")
  attempts          AssessmentAttempt[]  @relation("attemptUser")
  evaluations       AssessmentAttempt[]  @relation("evaluator")
  assessments       Assessment[]
  notificationsIn   Notification[]       @relation("recipient")
  notificationsOut  Notification[]       @relation("sender")
  auditLogs         AuditLog[]
}

model Training {
  id           String   @id @default(uuid())
  code         String   @unique // e.g. TRN-0001
  title        String
  description  String
  sopReference String?  // linked SOP number, e.g. SOP-QA-014
  department   String
  createdAt    DateTime @default(now())
  assignments  TrainingAssignment[]
  assessments  Assessment[]
}

model TrainingAssignment {
  id           String           @id @default(uuid())
  training     Training         @relation(fields: [trainingId], references: [id])
  trainingId   String
  user         User             @relation("assignee", fields: [userId], references: [id])
  userId       String
  assignedBy   User             @relation("assigner", fields: [assignedById], references: [id])
  assignedById String
  status       AssignmentStatus @default(ASSIGNED)
  dueDate      DateTime
  assignedAt   DateTime         @default(now())
  completedAt  DateTime?

  @@unique([trainingId, userId])
}

model Assessment {
  id            String    @id @default(uuid())
  training      Training  @relation(fields: [trainingId], references: [id])
  trainingId    String
  title         String
  passMarkPct   Int       @default(80) // GMP convention: 80% pass threshold
  scheduledFrom DateTime
  scheduledTo   DateTime
  createdBy     User      @relation(fields: [createdById], references: [id])
  createdById   String
  createdAt     DateTime  @default(now())
  questions     Question[]
  attempts      AssessmentAttempt[]
}

model Question {
  id           String     @id @default(uuid())
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId String
  text         String
  options      String[]   // 4 options
  correctIndex Int
  marks        Int        @default(1)
}

model AssessmentAttempt {
  id            String        @id @default(uuid())
  assessment    Assessment    @relation(fields: [assessmentId], references: [id])
  assessmentId  String
  user          User          @relation("attemptUser", fields: [userId], references: [id])
  userId        String
  answers       Int[]         // selected option index per question, -1 = unanswered
  score         Int
  totalMarks    Int
  status        AttemptStatus @default(SUBMITTED)
  remarks       String?
  submittedAt   DateTime      @default(now())
  evaluatedBy   User?         @relation("evaluator", fields: [evaluatedById], references: [id])
  evaluatedById String?
  evaluatedAt   DateTime?
}

model Notification {
  id          String   @id @default(uuid())
  recipient   User     @relation("recipient", fields: [recipientId], references: [id])
  recipientId String
  sender      User     @relation("sender", fields: [senderId], references: [id])
  senderId    String
  type        String   // ASSESSMENT_DUE | SUBMIT_REMINDER | EVALUATE_REMINDER | TRAINING_INFO
  message     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// Immutable audit trail (21 CFR Part 11 / ALCOA+): no update or delete API exists for this table.
model AuditLog {
  id        String   @id @default(uuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  action    String   // e.g. LOGIN, USER_CREATED, TRAINING_ASSIGNED, ATTEMPT_EVALUATED
  entity    String?
  entityId  String?
  details   String?
  ipAddress String?
  timestamp DateTime @default(now())
}
